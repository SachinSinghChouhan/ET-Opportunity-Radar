# LLM API Keys (get free tier at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=optional_openai_key_here

# News APIs (get free tier at https://newsapi.org)
NEWS_API_KEY=your_newsapi_key_here

# App Settings
DEMO_MODE=false
LOG_LEVEL=INFO
DB_PATH=./data/opportunity_radar.db

# Pipeline Settings
PIPELINE_INTERVAL_MINUTES=5
MAX_SIGNALS_PER_CYCLE=20
TOP_N_OPPORTUNITIES=5

# NSE Settings
NSE_REQUEST_DELAY_SECONDS=1.5
NSE_MAX_RETRIES=3
